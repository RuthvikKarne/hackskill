# =============================================================================
# HRIP — Environment Variables Template
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your-project.supabase.co:5432/postgres

# Local development (when using docker-compose)
# DATABASE_URL=postgresql+asyncpg://hrip:hrip_dev_password@localhost:5432/hrip_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM content here (with \n for newlines in single-line env vars)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_STORAGE_BUCKET=medical-files

# ── AI Engine ─────────────────────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8001
AI_ENGINE_API_KEY=your-ai-engine-api-key

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ── SMS Gateway ───────────────────────────────────────────────────────────────
SMS_GATEWAY_URL=https://api.your-sms-provider.com
SMS_GATEWAY_KEY=your-sms-api-key

# =============================================================================
# AI ENGINE (.env for ai-engine/)
# =============================================================================
# DATABASE_URL=postgresql+asyncpg://...  (same as backend)
# API_KEY=your-ai-engine-api-key
# MODEL_PATH=/app/models
# ENVIRONMENT=development

# =============================================================================
# FRONTEND (.env.local for frontend/)
# =============================================================================
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
